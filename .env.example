# Copy to .env for local development. Use strong unique values outside demos.
SECURE_API_ENVIRONMENT=development
SECURE_API_DATABASE_PATH=data/secure_system.db
SECURE_API_JWT_SECRET=replace-with-at-least-32-random-bytes

# Optional one-time bootstrap user. Use only for first setup, then remove.
SECURE_API_BOOTSTRAP_USERNAME=
SECURE_API_BOOTSTRAP_PASSWORD=
SECURE_API_BOOTSTRAP_FULL_NAME=Bootstrap Administrator
SECURE_API_BOOTSTRAP_ROLE=super_admin
SECURE_API_BOOTSTRAP_DISTRICT=state

SECURE_API_TOKEN_TTL_MINUTES=30
SECURE_API_RATE_LIMIT_PER_MINUTE=120
SECURE_API_MAX_REQUEST_BYTES=1048576
SECURE_API_ALLOWED_HOSTS=localhost,127.0.0.1,testserver
SECURE_API_CORS_ORIGINS=
